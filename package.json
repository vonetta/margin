{
  "name": "margin",
  "version": "1.0.0",
  "main": "app.js",
  "scripts": {
    "test": "NODE_ENV=test jest --runInBand --no-coverage --forceExit",
    "test:watch": "NODE_ENV=test jest --runInBand --watchAll --no-coverage --forceExit",
    "seed": "node src/config/seed.js",
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test:coverage": "NODE_ENV=test jest --runInBand --coverage --forceExit"
  },
  "jest": {
    "globalSetup": "./jest.globalSetup.js",
    "moduleNameMapper": {
      "flyerRenderer\\.js$": "<rootDir>/src/__mocks__/flyerRenderer.js",
      "flyerRenderer$": "<rootDir>/src/__mocks__/flyerRenderer.js"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(puppeteer|puppeteer-core)/)"
    ]
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@aws-sdk/client-s3": "^3.1073.0",
    "@google/generative-ai": "^0.24.1",
    "bcryptjs": "^3.0.3",
    "chrono-node": "^2.9.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.2.0",
    "ical-generator": "^11.0.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.1",
    "multer": "^2.2.0",
    "nodemon": "^3.1.14",
    "puppeteer": "^25.1.0",
    "qrcode": "^1.5.4",
    "rrule": "^2.8.1",
    "sharp": "^0.35.2"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "supertest": "^7.2.2"
  }
}
